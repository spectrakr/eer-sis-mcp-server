{
  "name": "eer-mcp",
  "version": "1.0.0",
  "description": "MCP Adapter Server for Spring Framework App (Command Pattern)",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index-stdio.ts --bundle --platform=node --outfile=dist/index-stdio.js --external:fsevents",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index-stdio.js",
    "dev": "ts-node src/index.ts",
    "dev:stdio": "ts-node src/index-stdio.ts",
    "watch": "tsc --watch",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0",
    "@slack/web-api": "^7.14.1",
    "axios": "^1.7.9",
    "axios-cookiejar-support": "^6.0.5",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "tough-cookie": "^6.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/tough-cookie": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
