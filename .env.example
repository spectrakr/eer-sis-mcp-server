# Spring App Server 기본 URL (scheme + host + port)
SPRING_BASE_URL=http://172.16.100.226:19090

# ajaxHandler 경로 (기본값: /enomix/common/ajaxHandler.ex)
SPRING_AJAX_PATH=/enomix/common/ajaxHandler.ex

# Spring 세션 ID (JSESSIONID 값)
# 브라우저 개발자 도구에서 쿠키의 JSESSIONID 값을 복사해서 입력하세요
SESSION_ID=your_jsessionid_value

# 도메인 ID (기본값: NODE0000000001)
SPRING_DOMAIN_ID=NODE0000000001

# MCP 어댑터 서버 포트
PORT=3000

# Slack Configuration
# Slack 봇 토큰 (https://api.slack.com/apps 에서 생성)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack 채널 ID (공유할 기본 채널)
SLACK_CHANNEL_ID=C0123456789
